#!name = 王派医学
#!desc = 支持版本: 26.05.13
#!author = @ios151
#!homepage = https://github.com/Yu9191/wpyx
#!icon = https://raw.githubusercontent.com/Yu9191/-/main/wpyx.png

[Argument]
logLevel = select, "info", "off", "error", "warn", "debug", "all", tag=日志级别

[MITM]
hostname = api-app.wangpaiyixue.cn, api-app-v2.wangpaiyixue.cn

[Script]
http-response ^https?:\/\/api-app(-v2)?\.wangpaiyixue\.cn\/v\d+\/(common\/ac|goods\/(detail|lists|section_info)|video\/vid_token|(chapter|exam|paper|question|knowledge)\/) requires-body=true, max-size=-1, timeout=20, tag=王派医学, script-path=https://raw.githubusercontent.com/Yu9191/wpyx/main/wpyx.js, argument=worker=https://wpyx-unlock.lovebabyforever.workers.dev&logLevel={{{logLevel}}}
