{
  "id": "@wpyx-unlock",
  "name": "王派医学",
  "icon": "https://api.iconify.design/twemoji/medical-symbol.svg",
  "icons": [
    "https://api.iconify.design/twemoji/medical-symbol.svg"
  ],
  "author": "@ios151",
  "repo": "https://github.com/Yu9191/wpyx",
  "keys": [
    "@wpyx-unlock.workerUrl",
    "@wpyx-unlock.logLevel"
  ],
  "settings": [
    {
      "id": "@wpyx-unlock.workerUrl",
      "name": "Worker 地址",
      "val": "",
      "type": "text",
      "desc": "已部署的 Cloudflare Worker URL, 形如 https://wpyx-unlock.xxx.workers.dev (不带尾斜杠)"
    },
    {
      "id": "@wpyx-unlock.logLevel",
      "name": "日志级别",
      "val": "info",
      "type": "selects",
      "items": [
        { "key": "off", "label": "关闭" },
        { "key": "error", "label": "错误" },
        { "key": "warn", "label": "警告" },
        { "key": "info", "label": "信息" },
        { "key": "debug", "label": "调试" },
        { "key": "all", "label": "全部" }
      ],
      "desc": "脚本日志详细程度"
    }
  ]
}
